{
  "author": "Rokoucha <dev@rokoucha.net>",
  "dependencies": {
    "@koa/router": "^8.0.8",
    "class-validator": "^0.11.1",
    "koa": "^2.11.0",
    "koa-logger": "^3.2.1",
    "log4js": "^6.1.2",
    "pg": "^7.18.2",
    "reflect-metadata": "^0.1.13",
    "transform-ts": "^0.3.0",
    "typeorm": "^0.2.24"
  },
  "description": "Scientia est potentia",
  "devDependencies": {
    "@types/koa": "^2.11.2",
    "@types/koa-logger": "^3.1.1",
    "@types/koa__router": "^8.0.2",
    "@types/log4js": "^2.3.5",
    "@types/node": "^13.9.2",
    "@typescript-eslint/eslint-plugin": "^2.24.0",
    "@typescript-eslint/parser": "^2.24.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.10.0",
    "eslint-plugin-import": "^2.20.1",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.19.0",
    "prettier": "^2.0.1",
    "rimraf": "^3.0.2",
    "ts-node": "^8.7.0",
    "tsc-watch": "^4.2.3",
    "typescript": "^3.8.3"
  },
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "name": "scienest",
  "private": true,
  "repository": "ssh://git@github.com/rokoucha/scienest.git",
  "scripts": {
    "build": "yarn run clean && tsc",
    "clean": "rimraf ./dist",
    "dev": "yarn run clean && tsc-watch --onSuccess \"node ./dist/index.js\"",
    "format:fix": "prettier --write \"./**/*.json\"",
    "format": "prettier \"./**/*.json\"",
    "lint:fix": "eslint --ext ts,tsx --fix ./src",
    "lint": "eslint --ext ts,tsx ./src",
    "migration:revert": "yarn run build && typeorm migration:revert",
    "migration:run": "yarn run build && typeorm migration:run",
    "migration:show": "yarn run build && typeorm migration:show",
    "start": "ts-node ./src/index.ts"
  },
  "version": "0.0.0"
}
